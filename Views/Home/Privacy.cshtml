@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container mt-5 fade-in">
    <h1 class="fw-bold mb-4">Privacy Policy</h1>

    
    <p class="text-muted">
        Last updated: 2026
    </p>

    <hr />

    <h4>1. Introduction</h4>
    <p>
        EventEase respects your privacy and is committed to protecting your personal data.
        This privacy policy explains how we handle your information when you use our application.
    </p>

    <h4>2. Information We Collect</h4>
    <ul>
        <li>Event and booking details</li>
        <li>Venue information</li>
        <li>Basic usage data to improve performance</li>
    </ul>

    <h4>3. How We Use Your Information</h4>
    <p>
        We use your data to manage events, bookings, and venues efficiently.
        This helps provide a smooth and organized experience for users.
    </p>

    <h4>4. Data Protection</h4>
    <p>
        We take appropriate security measures to protect your data from unauthorized access,
        alteration, or disclosure.
    </p>

    <h4>5. Third-Party Services</h4>
    <p>
        EventEase does not share your data with third parties. All information remains within the system.
    </p>

    <h4>6. Your Rights</h4>
    <p>
        You have the right to access, update, or delete your data within the application.
    </p>

    <h4>7. Contact Us</h4>
    <p>
        If you have any questions about this privacy policy, please contact us at:
        <br />
        <strong>support@eventease.com</strong>
    </p>
   

</div>
